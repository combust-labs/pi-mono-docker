#!/bin/bash
# SPDX-License-Identifier: Apache-2.0

# Base directory of this script (absolute path)
base=$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)

# Append text to system prompt (allows multiple)
use_append_system_prompt=()
# Continue previous session
use_continue=0
# Export session to HTML
use_export=""
# Load extension file (allows multiple)
use_extension=()
# List available models (optional search term)
use_list_models=""
# Output mode (text|json|rpc)
use_mode=""
# Model pattern or ID (required)
use_model=${PI_DEFAULT_MODEL:-}
# Model cycling patterns (allows multiple)
use_models=()
# Disable AGENTS.md/CLAUDE.md context files
use_no_context_files=0
# Disable extension discovery
use_no_extensions=0
# Disable prompt templates
use_no_prompt_templates=0
# Don't save session (ephemeral mode)
use_no_session=0
# Disable skills
use_no_skills=0
# Disable themes
use_no_themes=0
# Disable all tools
use_no_tools=0
# Disable startup network operations
use_offline=0
# Internal container port (used in -e PORT), default 3000
use_ppi_container_port=3000
# Host port (exposed to host), defaults to use_ppi_container_port if not set
use_ppi_host_port=""
# Non-interactive mode (process prompt and exit)
use_print=0
# Initial prompt to send to the agent
use_prompt=${PI_DEFAULT_PROMPT:-"Summarize current the project"}
# Load prompt template (allows multiple)
use_prompt_template=()
# Provider name
use_provider=""
# Select and resume a session
use_resume=0
# Use specific session
use_session=""
# Session storage directory (container path for pi)
use_session_dir="/sessions"
# Host session directory (source mount for /sessions volume)
use_host_session_dir="$(pwd)/.pi/sessions"
# Load skill file/directory (allows multiple)
use_skill=()
# System prompt (default: coding assistant prompt)
use_system_prompt=""
# Load theme file/directory (allows multiple)
use_theme=()
# Thinking level: off, minimal, low, medium, high, xhigh
use_thinking=""
# Tool allowlist (allows multiple)
use_tools=()
# Force verbose startup
use_verbose=0

# ppi-specific flags:
# -------------------

# Additional host files to mount (host-path:container-path:rw|ro)
use_ppi_host_add_path=()
# Attach agents directory
use_ppi_host_attach_agents=0
# Attach models.json file from host
use_ppi_host_attach_models_json=0
# Attach prompts directory
use_ppi_host_attach_prompts=0
# Skip prepending the default nickname prompt
use_ppi_no_ppi_prompts=0
# pi-mono container version
use_version=v0.67.6
# Override if Containerfile exists
if [ -f "${base}/container/Containerfile" ]; then
  use_version=$(grep -E '^ARG PI_MONO_VERSION=' "${base}/container/Containerfile" | cut -d'=' -f2)
fi

# Function to validate port
is_port() {
  local port=$1
  # Check if the input is a sequence of digits
  if [[ $port =~ ^[0-9]+$ ]]; then
      # Check if it falls within the valid range 1-65535
      if (( port >= 1 && port <= 65535 )); then
          return 0 # Valid
      fi
  fi
  return 1 # Invalid
}

# Function to validate thinking level
is_valid_thinking() {
  local level=$1
  case "$level" in
    off|minimal|low|medium|high|xhigh)
      return 0 # Valid
      ;;
    *)
      return 1 # Invalid
      ;;
  esac
}

# Function to validate mode
is_valid_mode() {
  local mode=$1
  case "$mode" in
    text|json|rpc)
      return 0 # Valid
      ;;
    *)
      return 1 # Invalid
      ;;
  esac
}

# Function to check if next argument is a flag (starts with -- or -)
is_flag() {
  local arg=$1
  [[ "${arg}" == --* ]] || [[ "${arg}" == -* ]]
}

while (( "$#" )); do
    case "${1}" in
        --append-system-prompt)
            use_append_system_prompt+=("${2}")
            shift 2
            ;;
        --continue|-c)
            use_continue=1
            shift
            ;;
        --export)
            use_export="${2}"
            shift 2
            ;;
        --extension|-e)
            use_extension+=("${2}")
            shift 2
            ;;
        --list-models)
            # Optional search argument - if next arg is not a flag, use it
            if (( "$#" > 1 )) && ! is_flag "${2}"; then
              use_list_models="${2}"
              shift 2
            else
              use_list_models="' '"
              shift
            fi
            ;;
        --mode)
            use_mode="${2}"
            shift 2
            ;;
        --model)
            use_model="${2}"
            shift 2
            ;;
        --no-context-files|-nc)
            use_no_context_files=1
            shift
            ;;
        --no-extensions|-ne)
            use_no_extensions=1
            shift
            ;;
        --no-prompt-templates|-np)
            use_no_prompt_templates=1
            shift
            ;;
        --no-session)
            use_no_session=1
            shift
            ;;
        --no-skills|-ns)
            use_no_skills=1
            shift
            ;;
        --no-themes)
            use_no_themes=1
            shift
            ;;
        --no-tools)
            use_no_tools=1
            shift
            ;;
        --offline)
            use_offline=1
            shift
            ;;
        --port)
          maybe_port="${2}"
          if is_port "${maybe_port}"; then
            use_port="${2}"
            shift 2
          else
            echo "Error: Invalid port ${maybe_port}"
            exit 1
          fi
          ;;
        --print|-p)
            use_print=1
            shift
            ;;
        --prompt)
            use_prompt="${2}"
            shift 2
            ;;
        --provider)
            use_provider="${2}"
            shift 2
            ;;
        --resume|-r)
            use_resume=1
            shift
            ;;
        --session)
            use_session="${2}"
            shift 2
            ;;
        --session-dir)
            use_session_dir="${2}"
            shift 2
            ;;
        --skill)
            use_skill+=("${2}")
            shift 2
            ;;
        --system-prompt)
            use_system_prompt="${2}"
            shift 2
            ;;
        --theme)
            use_theme+=("${2}")
            shift 2
            ;;
        --thinking)
            use_thinking="${2}"
            shift 2
            ;;
        --tools)
            use_tools+=("${2}")
            shift 2
            ;;
        # ppi-specific flags kept separate
        --host-sessions-dir)
            use_host_session_dir="${2}"
            shift 2
            ;;
        --ppi-host-add-path)
            use_ppi_host_add_path+=("${2}")
            shift 2
            ;;
        --ppi-host-attach-agents)
            use_ppi_host_attach_agents=1
            shift
            ;;
        --ppi-host-attach-models-json)
            use_ppi_host_attach_models_json=1
            shift
            ;;
        --ppi-host-attach-prompts)
            use_ppi_host_attach_prompts=1
            shift
            ;;
        --ppi-no-ppi-prompts)
            use_ppi_no_ppi_prompts=1
            shift
            ;;
        --version)
            use_version="${2}"
            shift 2
            ;;
        --ppi-container-port)
            if is_port "${2}"; then
              use_ppi_container_port="${2}"
              shift 2
            else
              echo "Error: Invalid port ${2}"
              exit 1
            fi
            ;;
        --ppi-host-port)
            if is_port "${2}"; then
              use_ppi_host_port="${2}"
              shift 2
            else
              echo "Error: Invalid port ${2}"
              exit 1
            fi
            ;;
        -*)
            echo "Error: Unsupported flag ${1}" >&2
            exit 1
            ;;
    esac
done

# Validate that model is provided
if [[ -z "${use_model}" ]]; then
  echo "Error: --model is required" >&2
  exit 1
fi

# Validate thinking level if provided
if [[ -n "${use_thinking}" ]] && ! is_valid_thinking "${use_thinking}"; then
  echo "Warning: Invalid thinking level \"${use_thinking}\". Valid values: off, minimal, low, medium, high, xhigh" >&2
  use_thinking=""
fi

# Validate mode if provided
if [[ -n "${use_mode}" ]] && ! is_valid_mode "${use_mode}"; then
  echo "Warning: Invalid mode \"${use_mode}\". Valid values: text, json, rpc" >&2
  use_mode=""
fi

# If host port not explicitly set, default to container port
[[ -z "${use_ppi_host_port}" ]] && use_ppi_host_port="${use_ppi_container_port}"

# Create session directory only if --no-session is not specified
if [[ "${use_no_session}" != "1" ]] && [ ! -d "${use_host_session_dir}" ]; then
  echo "still creating..."
  mkdir -p "${use_host_session_dir}"
fi

# Build multi-occurrence flags
_extension_flags=""
for ext in "${use_extension[@]}"; do
  _extension_flags="${_extension_flags}--extension \"${ext}\" "
done

_skill_flags=""
for sk in "${use_skill[@]}"; do
  _skill_flags="${_skill_flags}--skill \"${sk}\" "
done

_prompt_template_flags=""
for pt in "${use_prompt_template[@]}"; do
  _prompt_template_flags="${_prompt_template_flags}--prompt-template \"${pt}\" "
done

_append_system_prompt_flags=""
if (( use_ppi_no_ppi_prompts == 0 )); then
  use_append_system_prompt=('Your nickname is unconditionally `'${use_model}'`, do not reinterpret. Use this value whenever you need to introduce yourself.' "${use_append_system_prompt[@]}")
fi
for asp in "${use_append_system_prompt[@]}"; do
  _append_system_prompt_flags="${_append_system_prompt_flags}--append-system-prompt '${asp}' "
done

_tools_flags=""
for tl in "${use_tools[@]}"; do
  _tools_flags="${_tools_flags}--tools \"${tl}\" "
done

_theme_flags=""
for th in "${use_theme[@]}"; do
  _theme_flags="${_theme_flags}--theme \"${th}\" "
done

_models_flags=""
for md in "${use_models[@]}"; do
  _models_flags="${_models_flags}--models \"${md}\" "
done

# Conditional volume mounts for ppi-host-attach flags
[[ "${use_ppi_host_attach_prompts}" == "1" ]] && _ppi_host_attach_prompts_vol="-v ${HOME}/.pi/agent/prompts:/root/.pi/agent/prompts:ro" || _ppi_host_attach_prompts_vol=""
[[ "${use_ppi_host_attach_agents}" == "1" ]] && _ppi_host_attach_agents_vol="-v ${HOME}/.pi/agent/agents:/root/.pi/agent/agents:ro" || _ppi_host_attach_agents_vol=""
[[ "${use_ppi_host_attach_models_json}" == "1" ]] && _ppi_host_attach_models_json_vol="-v ${HOME}/.pi/agent/models.json:/root/.pi/agent/models.json:ro" || _ppi_host_attach_models_json_vol=""

# Conditional session directory mount (only when --no-session is NOT provided)
[[ "${use_no_session}" != "1" ]] && _session_vol="-v ${use_host_session_dir}:${use_session_dir}" || _session_vol=""

# Build volume mounts for --ppi-host-add-path
_ppi_host_add_file_vols=""
for _f in "${use_ppi_host_add_path[@]}"; do
  _ppi_host_add_file_vols="${_ppi_host_add_file_vols}-v ${_f} "
done

if (( use_port >= 1  )) || [[ "${use_mode}" == "rpc" ]]; then

  docker run --rm -ti \
    -p ${use_ppi_host_port}:${use_ppi_container_port} \
    ${_ppi_host_attach_models_json_vol} \
    ${_ppi_host_attach_agents_vol} \
    ${_ppi_host_attach_prompts_vol} \
    ${_ppi_host_add_file_vols} \
    ${_session_vol} \
    -v $(pwd):/code \
    -e PORT=${use_ppi_container_port} \
    "localhost/pi-mono:${use_version}" --mode rpc

else

  [[ "${use_continue}" == "1" ]] && _continue_flags="--continue" || _continue_flags=""
  [[ "${use_no_context_files}" == "1" ]] && _no_context_files_flags="--no-context-files" || _no_context_files_flags=""
  [[ "${use_no_extensions}" == "1" ]] && _no_extensions_flags="--no-extensions" || _no_extensions_flags=""
  [[ "${use_no_session}" == "1" ]] && _no_session_flags="--no-session" || _no_session_flags=""
  [[ "${use_no_skills}" == "1" ]] && _no_skills_flags="--no-skills" || _no_skills_flags=""
  [[ "${use_no_prompt_templates}" == "1" ]] && _no_prompt_templates_flags="--no-prompt-templates" || _no_prompt_templates_flags=""
  [[ "${use_no_themes}" == "1" ]] && _no_themes_flags="--no-themes" || _no_themes_flags=""
  [[ "${use_no_tools}" == "1" ]] && _no_tools_flags="--no-tools" || _no_tools_flags=""
  [[ "${use_offline}" == "1" ]] && _offline_flags="--offline" || _offline_flags=""
  [[ "${use_print}" == "1" ]] && _print_flags="--print" || _print_flags=""
  [[ "${use_resume}" == "1" ]] && _resume_flags="--resume" || _resume_flags=""
  [[ "${use_verbose}" == "1" ]] && _verbose_flags="--verbose" || _verbose_flags=""

  temp_file=$(mktemp)
  cat <<EOF > "${temp_file}"
#!/bin/bash
/opt/agent/pi-mono/packages/coding-agent/dist/pi --model ${use_model} \\
  ${_append_system_prompt_flags} \\
  ${_continue_flags} \\
  ${_extension_flags} \\
  ${_models_flags} \\
  ${_no_context_files_flags} \\
  ${_no_extensions_flags} \\
  ${_no_prompt_templates_flags} \\
  ${_no_session_flags} \\
  ${_no_skills_flags} \\
  ${_no_themes_flags} \\
  ${_no_tools_flags} \\
  ${_offline_flags} \\
  ${_print_flags} \\
  ${_prompt_template_flags} \\
  ${_resume_flags} \\
  ${_skill_flags} \\
  ${_theme_flags} \\
  ${_tools_flags} \\
  ${_verbose_flags} \\
  ${use_export:+--export "${use_export}"} \\
  ${use_list_models:+--list-models${use_list_models:+" ${use_list_models}"}} \\
  ${use_mode:+--mode "${use_mode}"} \\
  ${use_provider:+--provider "${use_provider}"} \\
  ${use_session:+--session "${use_session}"} \\
  ${use_session_dir:+--session-dir "${use_session_dir}/--code--"} \\
  ${use_system_prompt:+--system-prompt "${use_system_prompt}"} \\
  ${use_thinking:+--thinking "${use_thinking}"} \\
  "${use_prompt}"
EOF
  trap 'rm -f "$temp_file"' EXIT

  # remove any line where the trimmed value is unquoted '\',
  # those are empty lines, and we don't need them
  minimal=$(cat "${temp_file}" | grep -vE '^[[:space:]]*\\[[:space:]]*$')
  echo -e "$minimal" > "${temp_file}"

  docker run --rm -ti \
    -v "${temp_file}:/.pi/pi-run-with-args.sh:rw" \
    ${_ppi_host_attach_models_json_vol} \
    ${_ppi_host_attach_agents_vol} \
    ${_ppi_host_attach_prompts_vol} \
    ${_ppi_host_add_file_vols} \
    ${_session_vol} \
    -v "$(pwd):/code" \
    "localhost/pi-mono:${use_version}" --mode interactive
    
fi
