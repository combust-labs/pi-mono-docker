#!/bin/bash
# SPDX-License-Identifier: Apache-2.0

# Base directory of this script (absolute path)
base=$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)

use_port=0
use_model=${PI_DEFAULT_MODEL:-"gpt-oss-120b-MXFP4-Q8"}
use_prompt=${PI_DEFAULT_PROMPT:-"Summarize current the project"}
use_provider=""
use_system_prompt=""
use_append_system_prompt=""
use_continue=0
use_resume=0
use_no_session=0
use_verbose=0
use_offline=0
use_thinking=""
use_no_tools=0
use_no_extensions=0
use_no_skills=0
use_no_prompt_templates=0
use_no_themes=0
use_no_context_files=0
# Default version
use_version=v0.67.6
# Override if Containerfile exists
if [ -f "${base}/container/Containerfile" ]; then
  use_version=$(grep -E '^ARG PI_MONO_VERSION=' "${base}/container/Containerfile" | cut -d'=' -f2)
fi

# Function to validate port
is_port() {
  local port=$1
  # Check if the input is a sequence of digits
  if [[ $port =~ ^[0-9]+$ ]]; then
      # Check if it falls within the valid range 1-65535
      if (( port >= 1 && port <= 65535 )); then
          return 0 # Valid
      fi
  fi
  return 1 # Invalid
}

# Function to validate thinking level
is_valid_thinking() {
  local level=$1
  case "$level" in
    off|minimal|low|medium|high|xhigh)
      return 0 # Valid
      ;;
    *)
      return 1 # Invalid
      ;;
  esac
}

if [ ! -d "$(pwd)/.pi/sessions" ]; then
  mkdir -p "$(pwd)/.pi/sessions"
  touch "$(pwd)/.pi/sessions/.gitkeep"
fi

while (( "$#" )); do
    case "${1}" in
        --model)
            use_model="${2}"
            shift 2
            ;;
        --provider)
            use_provider="${2}"
            shift 2
            ;;
        --system-prompt)
            use_system_prompt="${2}"
            shift 2
            ;;
        --append-system-prompt)
            use_append_system_prompt="${2}"
            shift 2
            ;;
        --continue)
            use_continue=1
            shift
            ;;
        --resume)
            use_resume=1
            shift
            ;;
        --no-session)
            use_no_session=1
            shift
            ;;
        --verbose)
            use_verbose=1
            shift
            ;;
        --offline)
            use_offline=1
            shift
            ;;
        --no-tools)
            use_no_tools=1
            shift
            ;;
        --no-extensions)
            use_no_extensions=1
            shift
            ;;
        --no-skills)
            use_no_skills=1
            shift
            ;;
        --no-prompt-templates)
            use_no_prompt_templates=1
            shift
            ;;
        --no-themes)
            use_no_themes=1
            shift
            ;;
        --no-context-files)
            use_no_context_files=1
            shift
            ;;
        --thinking)
            use_thinking="${2}"
            shift 2
            ;;
        --prompt)
            use_prompt="${2}"
            shift 2
            ;;
        --port)
          maybe_port="${2}"
          if is_port "${maybe_port}"; then
            use_port="${2}"
            shift 2
          else
            echo "Error: Invalid port ${maybe_port}"
            exit 1
          fi
          ;;
        --version)
            use_version="${2}"
            shift 2
            ;;
        -*)
            echo "Error: Unsupported flag ${1}" >&2
            exit 1
            ;;
    esac
done

# Validate thinking level if provided
if [[ -n "${use_thinking}" ]] && ! is_valid_thinking "${use_thinking}"; then
  echo "Warning: Invalid thinking level \"${use_thinking}\". Valid values: off, minimal, low, medium, high, xhigh" >&2
  use_thinking=""
fi

if (( use_port >= 1  )); then

  docker run --rm -ti \
    -p 3000:3000 \
    -v ~/.gitconfig:/root/.gitconfig:ro \
    -v ~/.gitconfig-github-private.inc:/root/.gitconfig-github-private.inc:ro \
    -v ~/.pi/agent/models.json:/root/.pi/agent/models.json:ro \
    -v ~/.pi/agent/agents:/root/.pi/agent/agents:ro \
    -v ~/.pi/agent/extensions/read-website:/root/.pi/agent/extensions/read-website:ro \
    -v ~/.pi/agent/extensions/subagent:/root/.pi/agent/extensions/subagent:ro \
    -v ~/.pi/agent/prompts:/root/.pi/agent/prompts:ro \
    -v $(pwd)/.pi/sessions:/root/.pi/agent/sessions \
    -v $(pwd):/code \
    -e PORT=${use_port} \
    --entrypoint /opt/agent/pi-mono/node_modules/pi-rpc-http-server/bin/run.sh \
    "localhost/pi-mono:${use_version}"

else

  docker run --rm -ti \
    -v ~/.gitconfig:/root/.gitconfig:ro \
    -v ~/.gitconfig-github-private.inc:/root/.gitconfig-github-private.inc:ro \
    -v ~/.pi/agent/models.json:/root/.pi/agent/models.json:ro \
    -v ~/.pi/agent/agents:/root/.pi/agent/agents:ro \
    -v ~/.pi/agent/extensions/read-website:/root/.pi/agent/extensions/read-website:ro \
    -v ~/.pi/agent/extensions/subagent:/root/.pi/agent/extensions/subagent:ro \
    -v ~/.pi/agent/prompts:/root/.pi/agent/prompts:ro \
    -v $(pwd)/.pi/sessions:/root/.pi/agent/sessions \
    -v $(pwd):/code \
    "localhost/pi-mono:${use_version}" \
        --model "${use_model}" \
        ${use_provider:+--provider "${use_provider}"} \
        ${use_system_prompt:+--system-prompt "${use_system_prompt}"} \
        ${use_append_system_prompt:+--append-system-prompt "${use_append_system_prompt}"} \
        ${use_continue:+--continue} \
        ${use_resume:+--resume} \
        ${use_no_session:+--no-session} \
        ${use_verbose:+--verbose} \
        ${use_offline:+--offline} \
        ${use_no_tools:+--no-tools} \
        ${use_no_extensions:+--no-extensions} \
        ${use_no_skills:+--no-skills} \
        ${use_no_prompt_templates:+--no-prompt-templates} \
        ${use_no_themes:+--no-themes} \
        ${use_no_context_files:+--no-context-files} \
        ${use_thinking:+--thinking "${use_thinking}"} \
        "${use_prompt}"
    
fi
